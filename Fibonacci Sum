import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int N = sc.nextInt();

        int a = 0, b = 1, sum = 0;

        while (a <= N) {
            if (a % 2 == 0) sum += a;
            int c = a + b;
            a = b;
            b = c;
        }

        System.out.println(sum);
    }
}
