import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int N = sc.nextInt();
        int[] arr = new int[N];

        for (int i = 0; i < N; i++) arr[i] = sc.nextInt();

        HashSet<Integer> set = new HashSet<>();

        for (int i = 0; i < N; i++) {
            if (!set.contains(arr[i])) {
                System.out.print(arr[i] + " ");
                set.add(arr[i]);
            }
        }
    }
}
